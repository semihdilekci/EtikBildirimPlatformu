{
  "name": "@ethics/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "prisma generate --schema=prisma/schema.prisma && tsc -p tsconfig.json",
    "lint": "eslint .",
    "typecheck": "prisma generate --schema=prisma/schema.prisma && tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --exclude 'src/**/*.db.integration.spec.ts'",
    "test:integration": "vitest run src/modules/auth/__tests__/auth.db.integration.spec.ts src/audit/__tests__/audit.db.integration.spec.ts src/modules/dev-crypto-audit/__tests__/dev-crypto-audit.db.integration.spec.ts",
    "test:coverage": "vitest run --config vitest.auth.config.ts --coverage && vitest run --config vitest.authz.config.ts --coverage && vitest run --coverage",
    "test:coverage:auth": "vitest run --config vitest.auth.config.ts --coverage",
    "test:coverage:authz": "vitest run --config vitest.authz.config.ts --coverage",
    "dev": "dotenv -e .env.local -- tsx watch src/main.ts",
    "dev:run": "dotenv -e .env.local -- node --watch dist/main.js",
    "start": "node dist/main.js",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate:dev": "dotenv -e .env.local -- prisma migrate dev --schema=prisma/schema.prisma",
    "prisma:migrate:deploy": "dotenv -e .env.local -- prisma migrate deploy --schema=prisma/schema.prisma",
    "prisma:seed": "dotenv -e .env.local -- tsx prisma/seed.ts",
    "smoke:faz3": "dotenv -e .env.local -- tsx scripts/smoke-faz3.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@ethics/dto": "workspace:*",
    "@ethics/policy": "workspace:*",
    "@ethics/shared": "workspace:*",
    "@nestjs/common": "^11.0.12",
    "@nestjs/core": "^11.0.12",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.12",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.8.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-session": "^1.19.0",
    "helmet": "^8.2.0",
    "nestjs-pino": "^4.6.1",
    "passport": "^0.7.0",
    "passport-openidconnect": "^0.1.2",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@ethics/eslint-config": "workspace:*",
    "@ethics/test-fixtures": "workspace:*",
    "@nestjs/testing": "^11.1.26",
    "@testcontainers/postgresql": "^10.28.0",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/node": "^22.10.2",
    "@types/passport": "^1.0.17",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.8",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.17.0",
    "prisma": "^6.8.2",
    "supertest": "^7.2.2",
    "testcontainers": "^10.28.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
