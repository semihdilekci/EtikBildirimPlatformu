generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth & Users ───────────────────────────────────────────────────────────

model User {
  id                   String    @id @default(cuid())
  oidcSubjectId        String?   @unique @map("oidc_subject_id")
  employeeId           String?   @unique @map("employee_id") @db.VarChar(20)
  email                String    @unique
  displayName          String    @map("display_name")
  companyId            String?   @map("company_id")
  locationId           String?   @map("location_id")
  functionId           String?   @map("function_id")
  positionCode         String?   @map("position_code") @db.VarChar(50)
  managerUserId        String?   @map("manager_user_id")
  clearanceLevel       String    @default("NORMAL") @map("clearance_level")
  isGeneralSecretary   Boolean   @default(false) @map("is_general_secretary")
  isActive             Boolean   @default(true) @map("is_active")
  provisionedAt        DateTime? @map("provisioned_at")
  lastLoginAt          DateTime? @map("last_login_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  createdBy            String?   @map("created_by")

  company   Company?  @relation(fields: [companyId], references: [id])
  location  Location? @relation(fields: [locationId], references: [id])
  function  Function? @relation(fields: [functionId], references: [id])
  manager   User?     @relation("UserManager", fields: [managerUserId], references: [id])
  directReports User[] @relation("UserManager")

  rolesAssigned   UserRole[] @relation("UserRoleSubject")
  rolesGranted    UserRole[] @relation("UserRoleAssignedBy")
  rolesApproved   UserRole[] @relation("UserRoleApprovedBy")
  loginAttempts   LoginAttempt[]

  casesAsRapporteur  Case[] @relation("CaseRapporteur")
  casesAsActionOwner Case[] @relation("CaseActionOwner")
  caseTransitions    CaseTransition[]
  tasks                Task[]
  taskEvents           TaskEvent[]
  decisionVotes        DecisionVote[]
  documentsUploaded    Document[] @relation("DocumentUploader")
  documentAccessGrants DocumentAccessGrant[] @relation("DocumentAccessGrantUser")
  notifications        Notification[]

  @@index([companyId], map: "idx_users_company_id")
  @@index([isActive], map: "idx_users_is_active")
  @@map("users")
}

model UserRole {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  roleCode      String    @map("role_code")
  assignedBy    String    @map("assigned_by")
  approvedBy    String?   @map("approved_by")
  reason        String?
  isActive      Boolean   @default(true) @map("is_active")
  assignedAt    DateTime  @default(now()) @map("assigned_at")
  revokedAt     DateTime? @map("revoked_at")
  auditEventId  String?   @map("audit_event_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user          User  @relation("UserRoleSubject", fields: [userId], references: [id])
  assignedByUser User @relation("UserRoleAssignedBy", fields: [assignedBy], references: [id])
  approvedByUser User? @relation("UserRoleApprovedBy", fields: [approvedBy], references: [id])

  @@index([userId, isActive], map: "idx_user_roles_user_active")
  @@map("user_roles")
}

/// connect-pg-simple session store — sid/sess/expire convention
model UserSession {
  sid    String   @id @db.VarChar(255)
  sess   Json
  expire DateTime @db.Timestamp(6)

  @@index([expire], map: "idx_user_sessions_expire")
  @@map("user_sessions")
}

model LoginAttempt {
  id              String    @id @default(cuid())
  scopeKey        String    @unique @map("scope_key")
  ipAddressHash   String    @map("ip_address_hash")
  userId          String?   @map("user_id")
  trackingCode    String?   @map("tracking_code") @db.VarChar(14)
  failedCount     Int       @default(0) @map("failed_count")
  lockedUntil     DateTime? @map("locked_until")
  lastAttemptAt   DateTime  @map("last_attempt_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([userId], map: "idx_login_attempts_user_id")
  @@index([trackingCode], map: "idx_login_attempts_tracking_code")
  @@index([lockedUntil], map: "idx_login_attempts_locked_until")
  @@map("login_attempts")
}

// ─── Master Data ────────────────────────────────────────────────────────────

model Company {
  id              String    @id @default(cuid())
  name            String
  code            String    @unique @db.VarChar(20)
  sourceSystem    String?   @map("source_system")
  sourceRecordId  String?   @map("source_record_id")
  sourceUpdatedAt DateTime? @map("source_updated_at")
  syncRunId       String?   @map("sync_run_id")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  locations Location[]
  functions Function[]
  positions Position[]
  users     User[]
  reports   Report[]
  cases     Case[]

  @@index([isActive], map: "idx_companies_is_active")
  @@map("companies")
}

model Report {
  id                         String    @id @default(cuid())
  trackingCode               String    @unique @map("tracking_code") @db.VarChar(14)
  trackingCodePasswordHash   String    @map("tracking_code_password_hash")
  isAnonymous                Boolean   @default(true) @map("is_anonymous")
  reporterIdentityName       String?   @map("reporter_identity_name")
  reporterIdentityTitle      String?   @map("reporter_identity_title")
  reporterIdentityRelation   String?   @map("reporter_identity_relation")
  reporterContactEmail       String?   @map("reporter_contact_email")
  reporterContactPhone       String?   @map("reporter_contact_phone")
  reporterCountry            String?   @map("reporter_country") @db.VarChar(3)
  reporterCity               String?   @map("reporter_city") @db.VarChar(100)
  incidentCountry            String    @map("incident_country") @db.VarChar(3)
  incidentCity               String    @map("incident_city") @db.VarChar(100)
  incidentLocationDetail     String?   @map("incident_location_detail")
  companyId                  String    @map("company_id")
  categoryGroup              String    @map("category_group")
  categories                 String[]  @map("categories")
  isUncertainCategory        Boolean   @default(false) @map("is_uncertain_category")
  incidentDescription        String    @map("incident_description")
  incidentDateStart          DateTime? @map("incident_date_start") @db.Date
  incidentDateEnd            DateTime? @map("incident_date_end") @db.Date
  incidentIsOngoing          Boolean   @default(false) @map("incident_is_ongoing")
  incidentRecurrence         String?   @map("incident_recurrence")
  howReporterLearned         String?   @map("how_reporter_learned")
  previouslyReported         Boolean   @default(false) @map("previously_reported")
  previouslyReportedTo       String?   @map("previously_reported_to")
  urgentRiskFlag             Boolean   @default(false) @map("urgent_risk_flag")
  urgentRiskDescription      String?   @map("urgent_risk_description")
  involvedPersons            String?   @map("involved_persons")
  witnesses                  String?   @map("witnesses")
  categorySpecificData       String?   @map("category_specific_data")
  encryptionMetadata         Json      @map("encryption_metadata")
  status                     String    @default("SUBMITTED")
  confidentialityLevel       String    @default("SENSITIVE") @map("confidentiality_level")
  channel                    String    @default("WEB_FORM")
  kvkkConsentVersion         String    @map("kvkk_consent_version") @db.VarChar(20)
  kvkkConsentAt              DateTime  @map("kvkk_consent_at")
  language                   String    @default("tr") @db.VarChar(5)
  submittedAt                DateTime  @map("submitted_at")
  lastActivityAt             DateTime? @map("last_activity_at")
  caseId                     String?   @map("case_id")
  createdAt                  DateTime  @default(now()) @map("created_at")
  updatedAt                  DateTime  @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])
  caseRecord Case?
  attachments ReportAttachment[]
  secureMessages SecureMessage[]
  documents Document[]

  @@index([companyId], map: "idx_reports_company_id")
  @@index([status], map: "idx_reports_status")
  @@index([submittedAt], map: "idx_reports_submitted_at")
  @@index([confidentialityLevel], map: "idx_reports_confidentiality_level")
  @@index([caseId], map: "idx_reports_case_id")
  @@map("reports")
}

model ReportAttachment {
  id                 String   @id @default(cuid())
  reportId           String   @map("report_id")
  originalFilename   String   @map("original_filename")
  storageKey         String   @map("storage_key")
  encryptedDek       String   @map("encrypted_dek")
  kmsKeyId           String   @map("kms_key_id")
  contentSha256      String   @map("content_sha256") @db.VarChar(64)
  fileSizeBytes      BigInt   @map("file_size_bytes")
  mimeType           String   @map("mime_type") @db.VarChar(100)
  malwareScanStatus  String   @default("PENDING") @map("malware_scan_status")
  uploadedAt         DateTime @default(now()) @map("uploaded_at")
  uploadedBy         String   @map("uploaded_by") @db.VarChar(50)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId], map: "idx_report_attachments_report_id")
  @@index([malwareScanStatus], map: "idx_report_attachments_scan_status")
  @@map("report_attachments")
}

model SecureMessage {
  id                   String   @id @default(cuid())
  reportId             String   @map("report_id")
  direction            String
  senderType           String   @map("sender_type")
  senderUserId         String?  @map("sender_user_id")
  messageBody          String   @map("message_body")
  attachmentsMetadata  String?  @map("attachments_metadata")
  encryptionMetadata   Json     @map("encryption_metadata")
  isRead               Boolean  @default(false) @map("is_read")
  createdAt            DateTime @default(now()) @map("created_at")

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId], map: "idx_sm_report_id")
  @@index([direction], map: "idx_sm_direction")
  @@index([createdAt], map: "idx_sm_created_at")
  @@map("secure_messages")
}

model Location {
  id              String    @id @default(cuid())
  companyId       String    @map("company_id")
  name            String
  code            String    @db.VarChar(20)
  sourceSystem    String?   @map("source_system")
  sourceRecordId  String?   @map("source_record_id")
  sourceUpdatedAt DateTime? @map("source_updated_at")
  syncRunId       String?   @map("sync_run_id")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])
  users   User[]

  @@unique([companyId, code], map: "idx_locations_company_code")
  @@index([companyId], map: "idx_locations_company_id")
  @@index([isActive], map: "idx_locations_is_active")
  @@map("locations")
}

model Function {
  id              String    @id @default(cuid())
  companyId       String    @map("company_id")
  name            String
  code            String    @db.VarChar(20)
  sourceSystem    String?   @map("source_system")
  sourceRecordId  String?   @map("source_record_id")
  sourceUpdatedAt DateTime? @map("source_updated_at")
  syncRunId       String?   @map("sync_run_id")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])
  users   User[]

  @@unique([companyId, code], map: "idx_functions_company_code")
  @@index([companyId], map: "idx_functions_company_id")
  @@index([isActive], map: "idx_functions_is_active")
  @@map("functions")
}

model Position {
  id              String    @id @default(cuid())
  companyId       String    @map("company_id")
  name            String
  code            String    @db.VarChar(20)
  sourceSystem    String?   @map("source_system")
  sourceRecordId  String?   @map("source_record_id")
  sourceUpdatedAt DateTime? @map("source_updated_at")
  syncRunId       String?   @map("sync_run_id")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, code], map: "idx_positions_company_code")
  @@index([companyId], map: "idx_positions_company_id")
  @@index([isActive], map: "idx_positions_is_active")
  @@map("positions")
}

// ─── Config & Admin ───────────────────────────────────────────────────────────

model SystemSetting {
  id           String   @id @default(cuid())
  key          String   @unique
  value        Json
  category     String
  versionNo    Int      @default(1) @map("version_no")
  isActive     Boolean  @default(true) @map("is_active")
  approvedBy   String?  @map("approved_by")
  auditEventId String?  @map("audit_event_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([category], map: "idx_system_settings_category")
  @@map("system_settings")
}

model KvkkConsentVersion {
  id          String    @id @default(cuid())
  versionCode String    @unique @map("version_code") @db.VarChar(20)
  contentText String    @map("content_text")
  publishedAt DateTime? @map("published_at")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("kvkk_consent_versions")
}

model SlaPolicyConfig {
  id                       String   @id @default(cuid())
  taskType                 String   @unique @map("task_type")
  slaDuration              Int      @map("sla_duration")
  slaUnit                  String   @default("business_days") @map("sla_unit")
  warningThresholdHours    Int      @default(24) @map("warning_threshold_hours")
  dailyOverdueNotification Boolean  @default(true) @map("daily_overdue_notification")
  escalationRole           String   @default("council_secretary") @map("escalation_role")
  isActive                 Boolean  @default(true) @map("is_active")
  versionNo                Int      @default(1) @map("version_no")
  approvedBy               String?  @map("approved_by")
  auditEventId             String?  @map("audit_event_id")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  tasks Task[]

  @@map("sla_policy_configs")
}

model BusinessCalendarEntry {
  id           String   @id @default(cuid())
  date         DateTime @db.Date
  dayType      String   @map("day_type")
  description  String?
  isActive     Boolean  @default(true) @map("is_active")
  versionNo    Int      @default(1) @map("version_no")
  approvedBy   String?  @map("approved_by")
  auditEventId String?  @map("audit_event_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([date], map: "idx_business_calendar_date")
  @@index([dayType], map: "idx_business_calendar_day_type")
  @@map("business_calendar_entries")
}

// ─── Audit (append-only + chain hash DB triggers — Faz 3 İterasyon 3) ───────

model AuditOutbox {
  id             String    @id @default(cuid())
  occurredAt     DateTime  @map("occurred_at")
  eventType      String    @map("event_type")
  eventCategory  String    @map("event_category")
  severity       String
  actorType      String    @map("actor_type")
  actorId        String?   @map("actor_id")
  action         String
  outcome        String
  resourceType   String?   @map("resource_type")
  resourceId     String?   @map("resource_id")
  caseId         String?   @map("case_id")
  companyId      String?   @map("company_id")
  correlationId  String?   @map("correlation_id")
  idempotencyKey String?   @unique @map("idempotency_key")
  metadataJson   Json?     @map("metadata_json")
  dispatchStatus String    @default("PENDING") @map("dispatch_status")
  retryCount     Int       @default(0) @map("retry_count")
  errorCode      String?   @map("error_code")
  processedAt    DateTime? @map("processed_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([dispatchStatus], map: "idx_audit_outbox_dispatch_status")
  @@index([correlationId], map: "idx_audit_outbox_correlation_id")
  @@index([createdAt], map: "idx_audit_outbox_created_at")
  @@index([eventType], map: "idx_audit_outbox_event_type")
  @@map("audit_outbox")
}

model AuditEvent {
  id              String   @id @default(cuid())
  occurredAt      DateTime @map("occurred_at")
  recordedAt      DateTime @default(now()) @map("recorded_at")
  eventType       String   @map("event_type")
  eventCategory   String   @map("event_category")
  severity        String
  actorType       String   @map("actor_type")
  actorId         String?  @map("actor_id")
  action          String
  outcome         String
  correlationId   String?  @map("correlation_id")
  metadataJson    Json?    @map("metadata_json")
  prevHash        String?  @map("prev_hash")
  eventHash       String?  @map("event_hash")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([eventType], map: "idx_ae_event_type")
  @@index([occurredAt], map: "idx_ae_occurred_at")
  @@index([correlationId], map: "idx_ae_correlation_id")
  @@index([eventCategory], map: "idx_ae_event_category")
  @@map("audit_events")
}

// ─── Notification outbox stub (Faz 5 İterasyon 5 — Faz 8 dispatch) ───────────

model NotificationEvent {
  id                    String    @id @default(cuid())
  eventType             String    @map("event_type")
  channel               String
  recipientUserId       String?   @map("recipient_user_id")
  recipientTrackingCode String?   @map("recipient_tracking_code")
  templateId            String?   @map("template_id")
  caseId                String?   @map("case_id")
  dispatchStatus        String    @default("PENDING") @map("dispatch_status")
  retryCount            Int       @default(0) @map("retry_count")
  sentAt                DateTime? @map("sent_at")
  errorCode             String?   @map("error_code")
  correlationId         String?   @map("correlation_id")
  idempotencyKey        String?   @unique @map("idempotency_key")
  metadataJson          Json?     @map("metadata_json")
  createdAt             DateTime  @default(now()) @map("created_at")

  @@index([dispatchStatus], map: "idx_notification_events_dispatch_status")
  @@index([correlationId], map: "idx_notification_events_correlation_id")
  @@index([caseId], map: "idx_notification_events_case_id")
  @@map("notification_events")
}

// ─── In-app notifications + templates (Faz 8 — İterasyon 1) ──────────────────

model NotificationTemplate {
  id              String   @id @default(cuid())
  templateCode    String   @unique @map("template_code")
  name            String
  channel         String
  subjectTemplate String?  @map("subject_template")
  bodyTemplate    String   @map("body_template")
  isActive        Boolean  @default(true) @map("is_active")
  versionNo       Int      @default(1) @map("version_no")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  notifications Notification[]

  @@index([channel, isActive], map: "idx_notification_templates_channel_active")
  @@map("notification_templates")
}

model Notification {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  templateCode String    @map("template_code")
  title        String
  body         String
  caseId       String?   @map("case_id")
  taskId       String?   @map("task_id")
  isRead       Boolean   @default(false) @map("is_read")
  readAt       DateTime? @map("read_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  user     User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  template NotificationTemplate @relation(fields: [templateCode], references: [templateCode])

  @@index([userId, isRead, createdAt(sort: Desc)], map: "idx_notifications_user_read_created")
  @@index([userId, createdAt(sort: Desc)], map: "idx_notifications_user_created")
  @@map("notifications")
}

// ─── Case Management (Faz 5 — İterasyon 1) ───────────────────────────────────

model Case {
  id                    String    @id @default(cuid())
  reportId              String    @unique @map("report_id")
  currentState          String    @map("current_state")
  workflowVersion       String    @map("workflow_version") @db.VarChar(20)
  confidentialityLevel  String    @default("SENSITIVE") @map("confidentiality_level")
  companyId             String    @map("company_id")
  assignedRapporteurId  String?   @map("assigned_rapporteur_id")
  assignedActionOwnerId String?   @map("assigned_action_owner_id")
  openedAt              DateTime  @default(now()) @map("opened_at")
  closedAt              DateTime? @map("closed_at")
  optimisticLockVersion Int       @default(0) @map("optimistic_lock_version")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  createdBy             String    @map("created_by")

  report              Report           @relation(fields: [reportId], references: [id])
  company             Company          @relation(fields: [companyId], references: [id])
  assignedRapporteur  User?            @relation("CaseRapporteur", fields: [assignedRapporteurId], references: [id])
  assignedActionOwner User?            @relation("CaseActionOwner", fields: [assignedActionOwnerId], references: [id])
  transitions         CaseTransition[]
  tasks                 Task[]
  decisionVotes         DecisionVote[]
  documents             Document[]

  @@index([currentState], map: "idx_cases_current_state")
  @@index([companyId], map: "idx_cases_company_id")
  @@index([confidentialityLevel], map: "idx_cases_confidentiality_level")
  @@index([assignedRapporteurId], map: "idx_cases_assigned_rapporteur")
  @@index([assignedActionOwnerId], map: "idx_cases_assigned_action_owner")
  @@index([openedAt], map: "idx_cases_opened_at")
  @@map("cases")
}

model CaseTransition {
  id                 String   @id @default(cuid())
  caseId             String   @map("case_id")
  fromState          String   @map("from_state")
  toState            String   @map("to_state")
  command            String
  actorType          String   @map("actor_type")
  performedByUserId  String?  @map("performed_by_user_id")
  reasonTextMasked   String?  @map("reason_text_masked")
  encryptionMetadata Json?    @map("encryption_metadata")
  idempotencyKey     String   @unique @map("idempotency_key")
  auditEventId       String?  @map("audit_event_id")
  transitionedAt     DateTime @default(now()) @map("transitioned_at")
  createdAt          DateTime @default(now()) @map("created_at")

  case            Case  @relation(fields: [caseId], references: [id])
  performedByUser User? @relation(fields: [performedByUserId], references: [id])
  tasksCreated    Task[]
  decisionVotes   DecisionVote[]
  documents              Document[]
  documentAccessGrants   DocumentAccessGrant[]

  @@index([caseId], map: "idx_ct_case_id")
  @@index([transitionedAt], map: "idx_ct_transitioned_at")
  @@index([toState], map: "idx_ct_to_state")
  @@map("case_transitions")
}

// ─── Task Management (Faz 6 — İterasyon 1) ────────────────────────────────────

model Task {
  id                     String    @id @default(cuid())
  caseId                 String    @map("case_id")
  taskType               String    @map("task_type")
  status                 String    @default("PENDING")
  assignedRole           String    @map("assigned_role")
  assignedUserId         String?   @map("assigned_user_id")
  assignedCompanyId      String?   @map("assigned_company_id")
  assignedFunctionId     String?   @map("assigned_function_id")
  dueAt                  DateTime? @map("due_at")
  slaPolicyId            String?   @map("sla_policy_id")
  slaPausedAt            DateTime? @map("sla_paused_at")
  slaPauseReason         String?   @map("sla_pause_reason")
  createdByTransitionId  String    @map("created_by_transition_id")
  completedByUserId      String?   @map("completed_by_user_id")
  completedAt            DateTime? @map("completed_at")
  outcome                String?
  delegatedFromTaskId    String?   @map("delegated_from_task_id")
  visibilityPolicyId     String?   @map("visibility_policy_id")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")
  createdBy              String?   @map("created_by")

  case                 Case             @relation(fields: [caseId], references: [id])
  createdByTransition  CaseTransition   @relation(fields: [createdByTransitionId], references: [id])
  assignedUser         User?            @relation(fields: [assignedUserId], references: [id])
  slaPolicy            SlaPolicyConfig? @relation(fields: [slaPolicyId], references: [id])
  delegatedFromTask    Task?            @relation("TaskDelegation", fields: [delegatedFromTaskId], references: [id])
  delegatedTasks       Task[]           @relation("TaskDelegation")
  events               TaskEvent[]
  documents            Document[]

  @@index([caseId], map: "idx_tasks_case_id")
  @@index([status], map: "idx_tasks_status")
  @@index([assignedUserId], map: "idx_tasks_assigned_user")
  @@index([taskType], map: "idx_tasks_task_type")
  @@index([dueAt], map: "idx_tasks_due_at")
  @@index([createdByTransitionId], map: "idx_tasks_created_by_transition")
  @@map("tasks")
}

model TaskEvent {
  id           String   @id @default(cuid())
  taskId       String   @map("task_id")
  eventType    String   @map("event_type")
  actorType    String   @map("actor_type")
  actorUserId  String?  @map("actor_user_id")
  metadataJson Json?    @map("metadata_json")
  occurredAt   DateTime @default(now()) @map("occurred_at")
  createdAt    DateTime @default(now()) @map("created_at")

  task      Task  @relation(fields: [taskId], references: [id])
  actorUser User? @relation(fields: [actorUserId], references: [id])

  @@index([taskId], map: "idx_task_events_task_id")
  @@index([occurredAt], map: "idx_task_events_occurred_at")
  @@map("task_events")
}

// ─── Decision Votes (Faz 6 — İterasyon 4) ───────────────────────────────────

model DecisionVote {
  id                  String   @id @default(cuid())
  caseId              String   @map("case_id")
  transitionId        String   @map("transition_id")
  voterUserId         String   @map("voter_user_id")
  voteType            String   @map("vote_type")
  reasonText          String?  @map("reason_text")
  encryptionMetadata  Json?    @map("encryption_metadata")
  isSilentAcceptance  Boolean  @default(false) @map("is_silent_acceptance")
  createdBySystem     Boolean  @default(false) @map("created_by_system")
  votedAt             DateTime @default(now()) @map("voted_at")
  auditEventId        String?  @map("audit_event_id")
  createdAt           DateTime @default(now()) @map("created_at")

  case       Case           @relation(fields: [caseId], references: [id])
  transition CaseTransition @relation(fields: [transitionId], references: [id])
  voter      User           @relation(fields: [voterUserId], references: [id])

  @@unique([transitionId, voterUserId], map: "idx_dv_transition_voter_unique")
  @@index([caseId], map: "idx_dv_case_id")
  @@index([transitionId], map: "idx_dv_transition_id")
  @@map("decision_votes")
}

// ─── Document Management (Faz 7 — İterasyon 1) ──────────────────────────────

model Document {
  id                   String    @id @default(cuid())
  caseId               String    @map("case_id")
  reportId             String?   @map("report_id")
  taskId               String?   @map("task_id")
  transitionId         String?   @map("transition_id")
  documentCategory     String    @map("document_category")
  title                String
  currentVersionNo     Int       @default(1) @map("current_version_no")
  status               String    @default("QUARANTINED")
  confidentialityLevel String    @map("confidentiality_level")
  retentionPolicyId    String?   @map("retention_policy_id")
  archivedAt           DateTime? @map("archived_at")
  uploadedByUserId     String?   @map("uploaded_by_user_id")
  uploadedAt           DateTime  @default(now()) @map("uploaded_at")
  contentSealedAt      DateTime? @map("content_sealed_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  case         Case            @relation(fields: [caseId], references: [id])
  report       Report?         @relation(fields: [reportId], references: [id])
  task         Task?           @relation(fields: [taskId], references: [id])
  transition   CaseTransition? @relation(fields: [transitionId], references: [id])
  uploadedBy   User?                 @relation("DocumentUploader", fields: [uploadedByUserId], references: [id])
  versions     DocumentVersion[]
  accessGrants DocumentAccessGrant[]

  @@index([caseId], map: "idx_docs_case_id")
  @@index([documentCategory], map: "idx_docs_document_category")
  @@index([status], map: "idx_docs_status")
  @@index([confidentialityLevel], map: "idx_docs_confidentiality_level")
  @@index([uploadedAt], map: "idx_docs_uploaded_at")
  @@map("documents")
}

model DocumentVersion {
  id                        String    @id @default(cuid())
  documentId                String    @map("document_id")
  versionNo                 Int       @map("version_no")
  storageKeyCiphertext      String    @map("storage_key_ciphertext")
  encryptedDek              String    @map("encrypted_dek")
  kmsKeyId                  String    @map("kms_key_id")
  encryptionAlgorithm       String    @default("AES-256-GCM") @map("encryption_algorithm")
  contentSha256             String    @map("content_sha256") @db.VarChar(64)
  sizeBytes                 BigInt    @map("size_bytes")
  mimeType                  String    @map("mime_type") @db.VarChar(100)
  originalFilenameEncrypted String    @map("original_filename_encrypted")
  malwareScanStatus         String    @default("PENDING") @map("malware_scan_status")
  scannedAt                 DateTime? @map("scanned_at")
  uploadedByUserId          String?   @map("uploaded_by_user_id")
  createdAt                 DateTime  @default(now()) @map("created_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, versionNo], map: "idx_dv_document_version_unique")
  @@index([documentId], map: "idx_dv_document_id")
  @@map("document_versions")
}

model DocumentAccessGrant {
  id                     String    @id @default(cuid())
  documentId             String    @map("document_id")
  grantedToUserId        String?   @map("granted_to_user_id")
  grantedToRole          String?   @map("granted_to_role")
  grantScope             String    @default("FULL_ACCESS") @map("grant_scope")
  grantedByTransitionId  String?   @map("granted_by_transition_id")
  grantedAt              DateTime  @default(now()) @map("granted_at")
  revokedAt              DateTime? @map("revoked_at")
  createdAt              DateTime  @default(now()) @map("created_at")

  document            Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  grantedToUser       User?           @relation("DocumentAccessGrantUser", fields: [grantedToUserId], references: [id])
  grantedByTransition CaseTransition? @relation(fields: [grantedByTransitionId], references: [id])

  @@index([documentId], map: "idx_dag_document_id")
  @@index([grantedToUserId], map: "idx_dag_granted_to_user_id")
  @@index([grantedToRole], map: "idx_dag_granted_to_role")
  @@index([revokedAt], map: "idx_dag_revoked_at")
  @@map("document_access_grants")
}
