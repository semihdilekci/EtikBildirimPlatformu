# API ortam değişkenleri — isim ve açıklama (secret değer yazmayın)
# Kopyala: cp apps/api/.env.example apps/api/.env.local

# NODE_ENV — Ortam tanımı
# PORT — API sunucu portu

# DATABASE_URL — AWS RDS PostgreSQL bağlantı dizesi (zorunlu)
# Format: postgresql://USER:PASSWORD@your-db.region.rds.amazonaws.com:5432/ethics_dev?schema=public
# RDS SSL gerekiyorsa: ...?schema=public&sslmode=require

# OIDC_ISSUER_URL — OIDC provider issuer URL
# OIDC_CLIENT_ID — OIDC client identifier
# OIDC_CLIENT_SECRET — OIDC client secret (Secrets Manager / password manager)
# OIDC_CALLBACK_URL — OIDC callback endpoint URL

# SESSION_SECRET — Express session signing key (64+ karakter)
# SESSION_STORE_TABLE — Session store tablo adı (varsayılan: user_sessions)
# CSRF_SECRET — CSRF token signing key (64+ karakter)
# CORS_ALLOWED_ORIGINS — İzin verilen origin'ler (virgülle ayrılmış)

# AWS_REGION — AWS bölgesi (RDS ve S3 ile aynı olmalı)
# AWS_ACCESS_KEY_ID — IAM access key (dev: IAM user; staging/prod: ECS task role / Secrets Manager)
# AWS_SECRET_ACCESS_KEY — IAM secret key (dev: IAM user; staging/prod: Secrets Manager)
# AWS_KMS_KEY_ALIAS_FIELD — Per-field encryption KEK alias
# AWS_KMS_KEY_ALIAS_DOCUMENT — Per-document encryption KEK alias
# S3_BUCKET_DOCUMENTS — Doküman storage bucket (AWS S3)
# S3_BUCKET_QUARANTINE — Quarantine bucket (AWS S3)
# S3_ENDPOINT — Opsiyonel; yalnızca AWS dışı S3-compatible storage için. AWS S3'te tanımlamayın.

# SMTP_HOST — E-posta relay sunucusu
# SMTP_PORT — SMTP port
# SMTP_USER — SMTP kullanıcı
# SMTP_PASSWORD — SMTP parola
# SMTP_FROM — Gönderici adresi

# CLAMAV_HOST — AWS ECS ClamAV internal endpoint (host:port); Faz 7+
# CLAMAV_TIMEOUT_MS — Tarama timeout (ms); varsayılan 30000

# ARGON2_PEPPER — Anonim tracking parola pepper
# LOG_LEVEL — Log seviyesi
# LOG_REDACTION_ENABLED — Log redaction aktif mi
# OUTBOX_POLL_INTERVAL_MS — Outbox worker polling aralığı (ms)
# HR_SYNC_CRON — HR/SAP sync cron ifadesi
# PAGERDUTY_ROUTING_KEY — Alarm routing key (staging/prod)
