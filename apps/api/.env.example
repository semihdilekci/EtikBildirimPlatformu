# API ortam değişkenleri — isim ve açıklama (secret değer yazmayın)
# Kopyala: cp apps/api/.env.example apps/api/.env.local

NODE_ENV=development
PORT=3000

# DATABASE_URL — AWS RDS PostgreSQL bağlantı dizesi (zorunlu)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/ethics_dev?schema=public

# OIDC — Development: Google OAuth2/OIDC
OIDC_ISSUER_URL=https://accounts.google.com
OIDC_CLIENT_ID=your-google-client-id
OIDC_CLIENT_SECRET=your-google-client-secret
OIDC_CALLBACK_URL=http://localhost:5173/api/v1/auth/oidc/callback

# Session
SESSION_SECRET=change-me-to-a-random-string-at-least-32-characters-long
SESSION_STORE_TABLE=user_sessions
SESSION_ABSOLUTE_TIMEOUT_HOURS=8

# Frontend
WEB_APP_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Seed (opsiyonel) — Google OIDC sub ile eşleştirmek için
# SEED_SUPERADMIN_OIDC_SUB=your-google-oidc-subject-id

# Brute-force (OIDC login attempts by IP)
IP_HASH_PEPPER=change-me-dev-ip-pepper-min-16-chars
BRUTE_FORCE_MAX_ATTEMPTS=5
BRUTE_FORCE_LOCKOUT_MINUTES=15

# Logging
LOG_LEVEL=info

# AWS (Faz 3+)
# AWS_REGION — AWS bölgesi (RDS ve S3 ile aynı olmalı)
# AWS_ACCESS_KEY_ID — IAM access key
# AWS_SECRET_ACCESS_KEY — IAM secret key
# AWS_KMS_KEY_ALIAS_FIELD — Per-field encryption KEK alias
# AWS_KMS_KEY_ALIAS_DOCUMENT — Per-document encryption KEK alias
# S3_BUCKET_DOCUMENTS — Doküman storage bucket
# S3_BUCKET_QUARANTINE — Quarantine bucket

# CSRF (Faz 1 İterasyon 3)
CSRF_SECRET=change-me-to-a-random-csrf-secret-at-least-32-characters-long

# SMTP (Faz 8+)
# SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASSWORD, SMTP_FROM

# Tracking (Faz 4+)
# ARGON2_PEPPER — Anonim tracking parola pepper
