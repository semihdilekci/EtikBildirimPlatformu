# Web ortam değişkenleri — isim ve açıklama (secret değer yazmayın)
# Kopyala: cp apps/web/.env.example apps/web/.env.local

# VITE_API_BASE_URL — Backend API base URL (dev: Vite proxy üzerinden göreli path)
VITE_API_BASE_URL=/api/v1

# VITE_APP_ENV — Frontend ortam etiketi (development | staging | production)
VITE_APP_ENV=development

# VITE_API_PORT — Vite proxy hedef API portu (apps/api PORT ile aynı olmalı)
VITE_API_PORT=3003
