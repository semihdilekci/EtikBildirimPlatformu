# Kök ortam değişkenleri — isim ve açıklama (secret değer yazmayın)
# Kopyala: cp .env.example .env.local

# NODE_ENV — Ortam tanımı (development | staging | production)
# LOG_LEVEL — Log seviyesi (info, debug, warn, error)
# LOG_REDACTION_ENABLED — Log redaction aktif mi (true | false)

# Veritabanı (AWS RDS — local Docker yok)
# DATABASE_URL — RDS PostgreSQL bağlantısı; apps/api/.env.local içine yazın
# Format: postgresql://USER:PASSWORD@RDS_ENDPOINT:5432/DB_NAME?schema=public

# Object storage (AWS S3 — tüm ortamlar; detay apps/api/.env.local)
# AWS_REGION — AWS bölgesi
# S3_BUCKET_DOCUMENTS — Doküman bucket adı
# S3_BUCKET_QUARANTINE — Quarantine bucket adı

# Malware tarama (AWS ECS ClamAV — Faz 7+; detay apps/api/.env.local)
# CLAMAV_HOST — ECS internal endpoint; format: clamav-dev.internal:3310
# CLAMAV_TIMEOUT_MS — Tarama timeout (ms)
