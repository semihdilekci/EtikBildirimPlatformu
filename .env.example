# Kök ortam değişkenleri — isim ve açıklama (secret değer yazmayın)
# Kopyala: cp .env.example .env.local

# NODE_ENV — Ortam tanımı (development | staging | production)
# LOG_LEVEL — Log seviyesi (info, debug, warn, error)
# LOG_REDACTION_ENABLED — Log redaction aktif mi (true | false)

# Docker Compose servisleri (local dev)
# POSTGRES_PORT — Host port eşlemesi (varsayılan: 5432; meşgulse 5433)
# DATABASE_URL — PostgreSQL bağlantısı; format: postgresql://user:pass@host:5432/ethics_dev?schema=public
# S3_ENDPOINT — S3-compatible endpoint (dev: MinIO); format: http://localhost:9000
# CLAMAV_HOST — ClamAV tarama servisi host:port; format: localhost:3310
# CLAMAV_TIMEOUT_MS — Tarama timeout (ms)
